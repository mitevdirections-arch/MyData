# Copy this file as admin.env and fill required values.
# Required:
NAMESPACE=mydata-prod
IMAGE=ghcr.io/mydata/mydata-api:0.5.0
HOSTNAME=api.mydata.example

REPLICAS=3
UVICORN_WORKERS=3
HPA_MIN_REPLICAS=3
HPA_MAX_REPLICAS=40

# Ingress/TLS
INGRESS_CLASS=nginx
TLS_SECRET_NAME=mydata-api-tls

# cert-manager automation
CERT_MANAGER_ENABLED=true
CERT_MANAGER_CREATE_ISSUER=true
CERT_MANAGER_ISSUER_KIND=Issuer
CERT_MANAGER_ISSUER_NAME=mydata-letsencrypt
CERT_MANAGER_EMAIL=ops@mydata.example
CERT_MANAGER_ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Example DSN format: cockroachdb+psycopg://<user>:<password>@<host>:26257/mydata?sslmode=require
DATABASE_URL=
JWT_SECRET=CHANGE_ME_LONG_RANDOM
STORAGE_GRANT_SECRET=CHANGE_ME_LONG_RANDOM
GUARD_BOT_SIGNING_MASTER_SECRET=CHANGE_ME_LONG_RANDOM
STORAGE_ENDPOINT=https://minio.internal.example
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME

# Optional overrides:
CORS_ALLOW_ORIGINS=https://app.mydata.example
CORS_ALLOW_CREDENTIALS=false
SENSITIVE_RATE_LIMIT_PER_MINUTE=60
SENSITIVE_GET_RATE_LIMIT_PER_MINUTE=1200
REDIS_RATE_LIMIT_ENABLED=true
REDIS_URL=redis://redis-master.mydata.svc.cluster.local:6379/0
REDIS_KEY_PREFIX=mydata
API_LIST_LIMIT_MAX=500
CORE_ENTITLEMENT_CACHE_TTL_SECONDS=15
CORE_ENTITLEMENT_CACHE_MAX_ENTRIES=20000
DB_POOL_SIZE=80
DB_MAX_OVERFLOW=160
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_STATEMENT_TIMEOUT_MS=12000
GUARD_BOT_SIGNATURE_REQUIRED=true
STORAGE_PROVIDER=minio
STORAGE_BUCKET_VERIFICATION=mydata-verification
STORAGE_BUCKET_PUBLIC_ASSETS=mydata-public-assets
STORAGE_REGION=us-east-1
STORAGE_SECURE=true
STORAGE_PRESIGN_TTL_SECONDS=900
STORAGE_DOWNLOAD_PRESIGN_TTL_SECONDS=120
LICENSE_ISSUANCE_DEFAULT_MODE=SEMI

# Optional secret values:
# SUPERADMIN_STEP_UP_TOTP_SECRET=...
# SECURITY_ALERT_WEBHOOK_URL=https://hooks.example/...
