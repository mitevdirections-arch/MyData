# Environment template


APP_ENV=dev


API_PORT=8100





# CockroachDB (migrator profile)


DATABASE_URL=





# Auth core


JWT_SECRET=


JWT_ALGORITHM=HS256


JWT_AUDIENCE=mydata-api


JWT_ISSUER=mydata-auth


ACCESS_TOKEN_TTL_SECONDS=900


AUTH_DEV_TOKEN_ENABLED=false





# API docs + CORS (prod-safe defaults)


API_DOCS_ENABLED_IN_PROD=false


CORS_ALLOW_ORIGINS=https://app.mydata.local


CORS_ALLOW_CREDENTIALS=false


SECURITY_ENFORCE_PROD_CHECKS=true





# Request / rate-limit / query guard


REQUEST_ID_HEADER=X-Request-ID


SENSITIVE_RATE_LIMIT_PER_MINUTE=40


SENSITIVE_GET_RATE_LIMIT_PER_MINUTE=600


REDIS_RATE_LIMIT_ENABLED=true


REDIS_URL=


REDIS_KEY_PREFIX=mydata


API_LIST_LIMIT_MAX=500





# Runtime load protection


API_MAX_IN_FLIGHT_REQUESTS=250


API_QUEUE_WAIT_TIMEOUT_MS=90000


API_REQUEST_TIMEOUT_SECONDS=120
API_MAX_QUEUE_WAITERS=2000
API_OVERLOAD_RETRY_AFTER_SECONDS=2
API_RUNTIME_METRICS_WINDOW_SIZE=2048


API_RUNTIME_SLOW_REQUEST_MS=1500


API_RUNTIME_TIMING_HEADERS_ENABLED=false

API_STARTUP_ROUTES_PRINT_ENABLED=false
API_STARTUP_ROUTES_PRINT_MAX=2000


# Temporary performance profiling seam (explicitly gated)

PERF_PROFILING_ENABLED=false
PERF_PROFILING_METHODS=GET
PERF_PROFILING_PATH_PREFIXES=/orders
PERF_PROFILING_WINDOW_SIZE=4096


# Entity verification VIES provider runtime controls

ENTITY_VERIFICATION_VIES_ENABLED=false
ENTITY_VERIFICATION_VIES_WSDL_URL=https://ec.europa.eu/taxation_customs/vies/checkVatService.wsdl
ENTITY_VERIFICATION_VIES_SERVICE_URL=https://ec.europa.eu/taxation_customs/vies/services/checkVatService
ENTITY_VERIFICATION_VIES_CONNECT_TIMEOUT_SECONDS=2
ENTITY_VERIFICATION_VIES_READ_TIMEOUT_SECONDS=4
ENTITY_VERIFICATION_VIES_TOTAL_BUDGET_SECONDS=7
ENTITY_VERIFICATION_VIES_RETRY_COUNT=1
ENTITY_VERIFICATION_VIES_RETRY_BACKOFF_MS=300
ENTITY_VERIFICATION_VIES_COOLDOWN_SECONDS=60
MYDATA_ENTITY_VERIFICATION_MANUAL_CHECK_WINDOW_SECONDS=300
MYDATA_ENTITY_VERIFICATION_MANUAL_CHECK_WINDOW_MAX=20
MYDATA_ENTITY_VERIFICATION_MANUAL_CHECK_WINDOW_USER_MAX=20


# Tenant DB authz fast path


AUTHZ_TENANT_DB_FAST_PATH_ENABLED=false


AUTHZ_TENANT_DB_FAST_PATH_SHADOW_COMPARE_ENABLED=false


AUTHZ_TENANT_DB_FAST_PATH_SOURCE_VERSION=1






# Core entitlement cache


CORE_ENTITLEMENT_CACHE_TTL_SECONDS=15


CORE_ENTITLEMENT_CACHE_MAX_ENTRIES=20000





# DB pool controls


DB_POOL_SIZE=50


DB_MAX_OVERFLOW=100


DB_POOL_TIMEOUT_SECONDS=30


DB_POOL_RECYCLE_SECONDS=1800


DB_STATEMENT_TIMEOUT_MS=12000





# Guard heartbeat policy


GUARD_HEARTBEAT_BASE_SECONDS=1800


GUARD_HEARTBEAT_STALE_SECONDS=2100


GUARD_HEARTBEAT_GOOD_WEEK_DAYS=7


GUARD_HEARTBEAT_MAX_MULTIPLIER=4


GUARD_LICENSE_EXPIRY_WINDOW_HOURS=72


GUARD_LICENSE_EXPIRY_TIGHTEN_SECONDS=900


GUARD_LICENSE_EXPIRY_CRITICAL_HOURS=24


GUARD_LICENSE_EXPIRY_CRITICAL_SECONDS=600


GUARD_LICENSE_EXPIRY_EMERGENCY_HOURS=6


GUARD_LICENSE_EXPIRY_EMERGENCY_SECONDS=300





# Guard bot runtime


GUARD_BOT_SWEEP_INTERVAL_SECONDS=300


GUARD_BOT_SWEEP_LIMIT=200


GUARD_BOT_DEFAULT_MODE=SCHEDULED


GUARD_BOT_SIGNATURE_REQUIRED=false


GUARD_BOT_SIGNATURE_MAX_SKEW_SECONDS=120


GUARD_BOT_NONCE_TTL_SECONDS=300


GUARD_BOT_SIGNING_MASTER_SECRET=


GUARD_BOT_FAILED_SIGNATURE_LIMIT=5


GUARD_BOT_LOCKOUT_SECONDS=900


GUARD_BOT_CREDENTIAL_AUTO_ROTATE_DAYS=30


GUARD_BOT_CREDENTIAL_ROTATION_BATCH_SIZE=200


SECURITY_KEY_ROTATION_WORKER_ENABLED=false


GUARD_LICENSE_SNAPSHOT_MAX_CODES=256





# Licensing issuance flow (AUTO / SEMI / MANUAL)


LICENSE_ISSUANCE_DEFAULT_MODE=SEMI








# Deferred payments


PAYMENT_DEFERRED_DEFAULT_TERMS_DAYS=30


PAYMENT_DEFERRED_DEFAULT_GRACE_DAYS=3


PAYMENT_OVERDUE_SYNC_BATCH_SIZE=500


PAYMENT_AUTO_HOLD_ON_OVERDUE_DEFAULT=true


# Zero-retention storage policy


STORAGE_PROVIDER=minio


STORAGE_BUCKET_VERIFICATION=mydata-verification


STORAGE_ENDPOINT=http://127.0.0.1:9000


STORAGE_ACCESS_KEY=


STORAGE_SECRET_KEY=


STORAGE_REGION=us-east-1


STORAGE_SECURE=false


STORAGE_PRESIGN_TTL_SECONDS=900


STORAGE_DOWNLOAD_PRESIGN_TTL_SECONDS=120


STORAGE_HARD_DELETE_ENABLED=true


STORAGE_DELETE_BATCH_SIZE=200


STORAGE_DELETE_QUEUE_BATCH_SIZE=200


STORAGE_DELETE_RETRY_MAX_ATTEMPTS=8


STORAGE_DELETE_RETRY_BASE_SECONDS=30


STORAGE_DELETE_RETRY_MAX_SECONDS=3600





# Brokered storage grants


STORAGE_GRANT_SECRET=


STORAGE_GRANT_TTL_SECONDS_DEFAULT=120


STORAGE_GRANT_TTL_SECONDS_MAX=600





# Verification docs allow-list and retention


VERIFICATION_DOC_RETENTION_HOURS_DEFAULT=72


VERIFICATION_DOC_RETENTION_HOURS_MAX=168


VERIFICATION_DOC_ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg,text/plain,application/json,text/csv,text/markdown,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document


VERIFICATION_DOC_MAX_BYTES=15728640





# Public portal draft/publish + branding assets


STORAGE_BUCKET_PUBLIC_ASSETS=mydata-public-assets


PUBLIC_LOGO_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp,image/svg+xml


PUBLIC_LOGO_MAX_BYTES=2097152


PUBLIC_PAGE_DEFAULT_LOCALE=en


PUBLIC_PAGE_DEFAULT_CODE=HOME





# Secret rotation policy + versions


JWT_SECRET_VERSION=1


STORAGE_GRANT_SECRET_VERSION=1


GUARD_BOT_SIGNING_MASTER_SECRET_VERSION=1


SECRET_ROTATION_MAX_AGE_DAYS=90


JWT_SECRET_ROTATED_AT=


STORAGE_GRANT_SECRET_ROTATED_AT=


GUARD_BOT_SIGNING_MASTER_SECRET_ROTATED_AT=





# Superadmin step-up MFA (TOTP)


SUPERADMIN_STEP_UP_ENABLED=false


SUPERADMIN_STEP_UP_HEADER=X-Step-Up-Code


SUPERADMIN_STEP_UP_TOTP_SECRET=


SUPERADMIN_STEP_UP_PERIOD_SECONDS=30


SUPERADMIN_STEP_UP_WINDOW_STEPS=1





# Security alert pipeline


SECURITY_ALERTS_ENABLED=true


SECURITY_ALERTS_DELIVERY_MODE=LOG_ONLY


SECURITY_ALERT_WEBHOOK_URL=


SECURITY_ALERT_MIN_SEVERITY=HIGH


SECURITY_ALERT_DISPATCH_BATCH_SIZE=200


SECURITY_ALERT_RETRY_MAX_ATTEMPTS=8


SECURITY_ALERT_RETRY_BASE_SECONDS=30


SECURITY_ALERT_RETRY_MAX_SECONDS=3600





# Support gate/session controls


SUPPORT_DOOR_OPEN_DEFAULT_MINUTES=30


SUPPORT_DOOR_OPEN_MAX_MINUTES=240


SUPPORT_SESSION_TTL_MINUTES=60


SUPPORT_SESSION_TTL_MAX_MINUTES=480


SUPPORT_TOKEN_TTL_SECONDS=900


SUPPORT_CHAT_MAX_MESSAGE_CHARS=8000


SUPPORT_MESSAGES_LIST_LIMIT_MAX=500





# Prod gate optional runtime bug scan


PROD_GATE_BUG_SCAN_ENABLED=false


PROD_GATE_BUG_SCAN_API_BASE=


PROD_GATE_BUG_SCAN_TOKEN=


PROD_GATE_BUG_SCAN_ITERATIONS=2


PROD_GATE_BUG_SCAN_WORKERS=8


PROD_GATE_BUG_SCAN_TIMEOUT_SECONDS=5


PROD_GATE_BUG_SCAN_SLOW_MS=1500


PROD_GATE_BUG_SCAN_MAX_ENDPOINTS=200


PROD_GATE_BUG_SCAN_INCLUDE_PREFIXES=


PROD_GATE_BUG_SCAN_EXCLUDE_PREFIXES=/docs,/redoc,/openapi.json,/auth/dev-token


PROD_GATE_BUG_SCAN_INCLUDE_PROTECTED_WITHOUT_TOKEN=false


# Prod gate optional migration smoke


PROD_GATE_MIGRATIONS_SMOKE_ENABLED=false


PROD_GATE_MIGRATIONS_SMOKE_DATABASE_URL=


PROD_GATE_MIGRATIONS_SMOKE_ADMIN_DATABASE=


PROD_GATE_MIGRATIONS_SMOKE_SNAPSHOT_REVISION=


PROD_GATE_MIGRATIONS_SMOKE_EXPECT_TABLES=

