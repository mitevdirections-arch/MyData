  "sql": "\nSELECT license_type, license_id, valid_to\nFROM (\n  (\n    SELECT 0 AS priority, l.license_type, l.id AS license_id, l.valid_to\n    FROM licenses AS l\n    WHERE l.tenant_id = :tenant_id\n      AND l.status = 'ACTIVE'\n      AND l.valid_from <= now()\n      AND l.valid_to >= now()\n      AND l.license_type = 'STARTUP'\n    ORDER BY l.valid_to DESC\n    LIMIT 1\n  )\n  UNION ALL\n  (\n    SELECT 1 AS priority, l.license_type, l.id AS license_id, l.valid_to\n    FROM licenses AS l\n    WHERE l.tenant_id = :tenant_id\n      AND l.status = 'ACTIVE'\n      AND l.valid_from <= now()\n      AND l.valid_to >= now()\n      AND l.module_code = :module_code\n      AND l.license_type != 'CORE'\n      AND l.license_type != 'STARTUP'\n    ORDER BY l.valid_to DESC\n    LIMIT 1\n  )\n) AS entitlement_candidates\nORDER BY priority ASC, valid_to DESC\nLIMIT 1\n",
